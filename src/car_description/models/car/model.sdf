<?xml version="1.0" ?>
<sdf version="1.5">
  <!-- Car: teleported by set_entity_state, gravity disabled -->
  <model name="car">
    <static>false</static>
    <link name="body">
      <gravity>false</gravity>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz>
        </inertia>
      </inertial>

      <!-- Chassis (red) -->
      <collision name="chassis_col">
        <pose>-0.02 0 0.03 0 0 0</pose>
        <geometry><box><size>0.40 0.18 0.06</size></box></geometry>
      </collision>
      <visual name="chassis">
        <pose>-0.02 0 0.03 0 0 0</pose>
        <geometry><box><size>0.40 0.18 0.06</size></box></geometry>
        <material>
          <ambient>0.9 0.2 0.1 1.0</ambient>
          <diffuse>0.9 0.2 0.1 1.0</diffuse>
        </material>
      </visual>

      <!-- Wheels -->
      <visual name="wfl">
        <pose>0.12 0.105 0.023 -1.57 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="wfr">
        <pose>0.12 -0.105 0.023 -1.57 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="wrl">
        <pose>-0.14 0.105 0.023 -1.57 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="wrr">
        <pose>-0.14 -0.105 0.023 -1.57 0 0</pose>
        <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>


      <!-- LiDAR Visual -->
      <visual name="lidar_visual">
        <pose>0.15 0 0.1 0 0 0</pose>
        <geometry><cylinder><radius>0.04</radius><length>0.05</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.8 1</ambient><diffuse>0.1 0.1 0.8 1</diffuse></material>
      </visual>

      <!-- LiDAR Sensor -->
      <sensor name="lidar" type="ray">
        <pose>0.15 0 0.1 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>20.0</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="scan" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>body</frame_name>
        </plugin>
      </sensor>
    </link>

    <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>100.0</update_rate>
      <publish_rate>100.0</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>body</robot_base_frame>
    </plugin>
  </model>
</sdf>
